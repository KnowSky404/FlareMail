{
  "name": "flaremail",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "engines": {
    "bun": ">=1.3.10"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "XDG_CONFIG_HOME=/tmp svelte-kit sync && XDG_CONFIG_HOME=/tmp vite build",
    "preview": "bun run build && XDG_CONFIG_HOME=/tmp wrangler dev worker/index.ts --local",
    "check": "XDG_CONFIG_HOME=/tmp svelte-kit sync && XDG_CONFIG_HOME=/tmp svelte-check --tsconfig ./tsconfig.json",
    "cf:typegen": "XDG_CONFIG_HOME=/tmp wrangler types --env-interface CloudflareEnv",
    "db:migrate:local": "XDG_CONFIG_HOME=/tmp wrangler d1 execute flaremail-db --local --file ./schema.sql",
    "deploy:dry-run": "bun run build && bun ./scripts/deploy.mjs dry-run",
    "deploy": "bun run build && bun ./scripts/deploy.mjs"
  },
  "dependencies": {
    "@sveltejs/kit": "^2.55.0",
    "svelte": "^5.55.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/postcss": "^4.2.2",
    "postcss": "^8.5.8",
    "svelte-check": "^4.4.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "wrangler": "^4.76.0"
  }
}
